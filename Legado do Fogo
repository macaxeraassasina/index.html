            text-transform: uppercase;
        }

        .nav-scroll-link::before {
            content: '';
            position: absolute;
            bottom: 0; left: 0; width: 0; height: 1px;
            background: #ffb692;
            transition: width 0.4s ease;
            box-shadow: 0 0 10px #ee7125;
